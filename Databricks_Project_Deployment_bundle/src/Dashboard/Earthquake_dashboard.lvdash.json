{
  "datasets": [
    {
      "name": "09b2d48c",
      "displayName": "Earthquake_Detail",
      "queryLines": [
        "select * from silver.earthquake_data_final"
      ],
      "catalog": "testproject_dev",
      "schema": "default"
    },
    {
      "name": "91c14294",
      "displayName": "Earthquake_Type",
      "queryLines": [
        "select count(*) as total_magnitude_bucket\r\n",
        "\r\n",
        ",magnitude_bucket from (select CASE\r\n",
        "\r\n",
        "WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "\r\n",
        "WHEN mag BETWEEN 2 AND 3 THEN 'Minor (23)'\r\n",
        "\r\n",
        "WHEN mag BETWEEN 3 AND 4 THEN 'Light (34)'\r\n",
        "\r\n",
        "ELSE 'Moderate+ (4+)'\r\n",
        "\r\n",
        "END AS magnitude_bucket\r\n",
        "\r\n",
        "from silver.earthquake_data)\r\n",
        "\r\n",
        "group by magnitude_bucket"
      ],
      "catalog": "testproject_dev",
      "schema": "default"
    },
    {
      "name": "2583c83a",
      "displayName": "EarthQuake_Country",
      "queryLines": [
        "SELECT\r\n",
        "\r\n",
        "count(*) AS event_count,\r\n",
        "\r\n",
        "    CASE\r\n",
        "    WHEN size(split(place, ', ')) = 1. THEN split(place, ',')[0]\r\n",
        "    ELSE split(place, ', ') [1]\r\n",
        "   END AS country\r\n",
        "\r\n",
        "\r\n",
        "FROM(\r\n",
        "SELECT time,\r\n",
        "       title,\r\n",
        "       mag,\r\n",
        "       longitude,\r\n",
        "       place,\r\n",
        "       latitude\r\n",
        "\r\n",
        "from silver.earthquake_data_final\r\n",
        ")\r\n",
        "group by country"
      ],
      "catalog": "testproject_dev",
      "schema": "default"
    }
  ],
